generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CatalogStatus {
  active
  inactive
}

model Branch {
  id        String   @id @db.Uuid
  name      String
  phone     String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("branches")
}

model Category {
  id        String        @id @db.Uuid
  name      String
  order     Int           @default(999)
  status    CatalogStatus @default(active)
  imageUrl  String?       @map("image_url")
  createdAt DateTime      @default(now()) @map("created_at")
  products  Product[]

  @@map("categories")
}

model Product {
  id               String        @id @db.Uuid
  name             String
  price            Decimal       @db.Decimal(10, 2)
  categoryId       String        @map("category_id") @db.Uuid
  category         Category      @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  status           CatalogStatus @default(active)
  description      String?
  shortDescription String?       @map("short_description")
  imageUrl         String?       @map("image_url")
  order            Int           @default(999)
  isPromotion      Boolean       @default(false) @map("is_promotion")
  promotionTag     String?       @map("promotion_tag")
  promotionTagColor String?      @map("promotion_tag_color")
  createdAt        DateTime      @default(now()) @map("created_at")

  @@index([categoryId])
  @@index([status])
  @@map("products")
}

model Customer {
  id               String    @id @db.Uuid
  name             String
  phone            String    @unique
  password         String    // Hash de contraseña
  points           Int       @default(0)
  favoriteBranchId String?   @map("favorite_branch_id") @db.Uuid
  createdAt        DateTime  @default(now()) @map("created_at")
  sessions         Session[]
  orders           Order[]
  rewardRedemptions RewardRedemption[]

  @@map("customers")
}

model RedeemableProduct {
  id          String        @id @db.Uuid
  name        String
  pointsCost  Int           @map("points_cost")
  status      CatalogStatus @default(active)
  imageUrl    String?       @map("image_url")
  description String?
  order       Int           @default(999)
  createdAt   DateTime      @default(now()) @map("created_at")
  redemptions RewardRedemption[]

  @@index([status])
  @@map("redeemable_products")
}

model RewardRedemption {
  id                  String            @id @db.Uuid
  customerId          String            @map("customer_id") @db.Uuid
  customer            Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  redeemableProductId String            @map("redeemable_product_id") @db.Uuid
  redeemableProduct   RedeemableProduct @relation(fields: [redeemableProductId], references: [id], onDelete: Restrict)
  productName         String            @map("product_name")
  pointsCost          Int               @map("points_cost")
  createdAt           DateTime          @default(now()) @map("created_at")

  @@index([customerId])
  @@index([redeemableProductId])
  @@map("reward_redemptions")
}

model Session {
  id         String   @id @db.Uuid
  customerId String   @map("customer_id") @db.Uuid
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now()) @map("created_at")
  expiresAt  DateTime @map("expires_at")

  @@map("sessions")
}

model Order {
  id             String      @id @db.Uuid
  customerId     String?     @map("customer_id") @db.Uuid
  customer       Customer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerName   String      @map("customer_name")
  customerPhone  String      @map("customer_phone")
  branchId       String      @map("branch_id") @db.Uuid
  branchName     String      @map("branch_name")
  status         String      @default("pending") // pending, preparing, delivered, cancelled
  total          Decimal     @db.Decimal(10, 2)
  pointsEarned   Int         @default(0) @map("points_earned")
  pointsRedeemed Int         @default(0) @map("points_redeemed")
  deliveryType   String      @map("delivery_type") // delivery, pickup
  paymentMethod  String      @map("payment_method") // cash, card
  notes          String?
  createdAt      DateTime    @default(now()) @map("created_at")
  items          OrderItem[]

  @@map("orders")
}

model OrderItem {
  id          String  @id @db.Uuid
  orderId     String  @map("order_id") @db.Uuid
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String  @map("product_id") @db.Uuid
  productName String  @map("product_name")
  price       Decimal @db.Decimal(10, 2)
  quantity    Int
  meatPrep    String? @map("meat_prep")
  extras      String? // JSON string representing extras: name, price
  removals    String? // Comma-separated or JSON list of removals

  @@map("order_items")
}

model HomeBanner {
  id         String   @id @db.Uuid
  imageUrl   String   @map("image_url")
  title      String?
  subtitle   String?
  buttonText String?  @map("button_text")
  linkView   String?  @map("link_view")
  order      Int      @default(999)
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("home_banners")
}

model SystemSetting {
  key   String @id
  value String

  @@map("system_settings")
}

model Feedback {
  id        String   @id @db.Uuid
  rating    Int
  comment   String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("feedbacks")
}

